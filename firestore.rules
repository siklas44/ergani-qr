rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn() && userExists() && userDoc().role == 'admin';
    }

    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email == 'siklas44@gmail.com';
    }

    function hasStore(storeId) {
      return signedIn() && userExists()
        && userDoc().storeIds is list
        && storeId in userDoc().storeIds;
    }

    function hasPermission(perm) {
      return signedIn() && userExists()
        && userDoc().permissions is map
        && userDoc().permissions[perm] == true;
    }

    // ─── /users/{uid} ─────────────────────────────────────────
    match /users/{uid} {
      // Read: own doc OR admin
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());

      // Create:
      //  - admin can create any user doc (admin-creates-user flow)
      //  - bootstrap admin self-creates as admin
      //  - other emails self-create with role=null (pending)
      allow create: if signedIn() && (
        isAdmin() ||
        (request.auth.uid == uid
         && request.resource.data.email == request.auth.token.email
         && (
           (isBootstrapAdmin() && request.resource.data.role == 'admin') ||
           (!isBootstrapAdmin() && request.resource.data.role == null)
         ))
      );

      // Update / delete: admin only
      allow update, delete: if isAdmin();
    }

    // ─── /stores/{storeId} ────────────────────────────────────
    match /stores/{storeId} {
      // Read: admin OR user assigned to this store
      allow read: if isAdmin() || hasStore(storeId);
      // Write (CRUD stores): admin only
      allow write: if isAdmin();

      // Employees subcollection
      match /employees/{empId} {
        // Read: admin OR (assigned + viewEmployees permission)
        allow read: if isAdmin() ||
          (hasStore(storeId) && hasPermission('viewEmployees'));

        // Create: admin OR (assigned + addEmployees)
        allow create: if isAdmin() ||
          (hasStore(storeId) && hasPermission('addEmployees'));

        // Update:
        //  - admin
        //  - or assigned + editEmployees (full edit)
        //  - or assigned + tickDays AND only weekTicks field is being changed
        allow update: if isAdmin()
          || (hasStore(storeId) && hasPermission('editEmployees'))
          || (hasStore(storeId) && hasPermission('tickDays')
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['weekTicks']));

        // Delete: admin OR (assigned + deleteEmployees)
        allow delete: if isAdmin() ||
          (hasStore(storeId) && hasPermission('deleteEmployees'));
      }
    }

    // Default: everything else denied
  }
}
